# Copy to .env and fill in. NEVER commit .env.

# ElevenLabs (Agents Platform)
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID_ESTIMATOR=
ELEVENLABS_AGENT_ID_CALLER=
# Persona agents (the simulated counsellors)
ELEVENLABS_AGENT_ID_PERSONA_COMMISSION=
ELEVENLABS_AGENT_ID_PERSONA_FEEHIDER=
ELEVENLABS_AGENT_ID_PERSONA_STONEWALL=
# Phone number id from ElevenLabs > Phone Numbers after importing the Twilio number
ELEVENLABS_PHONE_NUMBER_ID=
