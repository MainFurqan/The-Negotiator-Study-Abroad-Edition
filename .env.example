# Copy to .env and fill in. NEVER commit .env.

# ElevenLabs (Agents Platform)
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID_ESTIMATOR=
ELEVENLABS_AGENT_ID_CALLER=
# Persona agents (the simulated counsellors)
ELEVENLABS_AGENT_ID_PERSONA_COMMISSION=
ELEVENLABS_AGENT_ID_PERSONA_FEEHIDER=
ELEVENLABS_AGENT_ID_PERSONA_STONEWALL=
# Phone number id from ElevenLabs > Phone Numbers after importing the Twilio number
ELEVENLABS_PHONE_NUMBER_ID=

# Twilio (trial — can only call verified numbers)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
# Your own verified phone (Tier B counterparty)
VERIFIED_TARGET_NUMBER=

# OpenAI (document OCR / parsing — gpt-4o-mini vision)
OPENAI_API_KEY=

# Public URL of the FastAPI backend (ngrok tunnel), no trailing slash
PUBLIC_BASE_URL=

# Optional: Google Places (call-list generation); OSM Overpass used if empty
GOOGLE_PLACES_API_KEY=
