# Live FX (GBP->PKR). Defaults are sensible; all optional.
# FX_DISABLE=1 forces the static config rate (offline demos).
# FX_TTL_SECONDS caches a fetched rate (default 21600 = 6h).
# NEGOTIATOR_FX_CACHE points the on-disk cache at a persistent path (e.g. /data/fx_cache.json).
FX_DISABLE=
FX_TTL_SECONDS=
NEGOTIATOR_FX_CACHE=
